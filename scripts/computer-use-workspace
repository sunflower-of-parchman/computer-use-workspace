#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SOURCE="${SCRIPT_DIR}/computer-use-workspace.swift"
BINARY="${SCRIPT_DIR}/.build/computer-use-workspace-cli"

if [[ ! -x "${BINARY}" || "${SOURCE}" -nt "${BINARY}" ]]; then
  echo "computer-use-workspace needs a current local build." >&2
  echo "Run: \"${SCRIPT_DIR}/build.sh\"" >&2
  exit 70
fi

exec "${BINARY}" "$@"
